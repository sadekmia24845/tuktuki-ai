# ==========================================================================
# Tuktuki AI — Backend Environment Variables
# Copy this file to ".env" and fill in your real values.
# NEVER commit your actual .env file to GitHub.
# ==========================================================================

# Your Google Gemini API key.
# Get one for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# The Gemini model to use.
# Options include: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Port the backend server will run on locally.
# Render will automatically override this with its own PORT variable.
PORT=5000

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" during development, and your GitHub Pages URL in production.
# Example: https://yourusername.github.io
ALLOWED_ORIGIN=*
